NODE_ENV=development
PORT=4000
CORS_ORIGIN=*
LOG_LEVEL=info
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/freshops-ai?retryWrites=true&w=majority
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_S3_BUCKET=<your_s3_bucket_name>
AWS_S3_PREFIX=freshops/uploads
# Optional. Use this when serving assets via custom domain/CDN.
AWS_S3_PUBLIC_BASE_URL=
CLARIFAI_PAT=<your_clarifai_pat>
CLARIFAI_USER_ID=<your_clarifai_user_id>
CLARIFAI_APP_ID=<your_clarifai_app_id>
CLARIFAI_MODEL_ID=food-item-recognition
